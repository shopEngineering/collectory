{
  "key": "firearms",
  "name": "Firearms",
  "icon": "firearm",
  "color": "#52684f",
  "description": "Serial numbers, specifications, NRA condition grading, NFA/tax-stamp tracking, range sessions with target photos, cleaning and modification history.",
  "fields": [
    { "key": "manufacturer", "label": "Manufacturer", "type": "text", "section": "Identity", "showInTable": true, "showOnCard": true, "placeholder": "Colt, Winchester, Smith & Wesson…" },
    { "key": "model", "label": "Model", "type": "text", "section": "Identity", "showInTable": true, "showOnCard": true },
    { "key": "serial_number", "label": "Serial Number", "type": "text", "section": "Identity", "showInTable": true },
    { "key": "firearm_type", "label": "Type", "type": "select", "section": "Identity", "showInTable": true, "options": ["Pistol", "Revolver", "Rifle", "Shotgun", "Receiver / Frame", "Muzzleloader", "Other"] },
    { "key": "caliber", "label": "Caliber / Gauge", "type": "text", "section": "Identity", "showInTable": true, "showOnCard": true, "placeholder": ".45 ACP, .30-06, 12 ga…" },
    { "key": "country_of_origin", "label": "Country of Origin", "type": "text", "section": "Identity" },
    { "key": "manufacture_year", "label": "Year of Manufacture", "type": "year", "section": "Identity", "help": "From serial-number range, proof/date code, or factory letter" },
    { "key": "importer_marks", "label": "Importer Marks", "type": "text", "section": "Identity" },
    { "key": "action", "label": "Action", "type": "select", "section": "Specifications", "options": ["Semi-Auto", "Bolt Action", "Lever Action", "Pump Action", "Break Action", "Single Shot", "Revolver — SA", "Revolver — DA/SA", "Full Auto / Select Fire", "Muzzleloader", "Other"] },
    { "key": "barrel_length", "label": "Barrel Length", "type": "number", "unit": "in", "section": "Specifications" },
    { "key": "capacity", "label": "Capacity", "type": "number", "unit": "rds", "section": "Specifications" },
    { "key": "finish", "label": "Finish", "type": "select", "section": "Specifications", "options": ["Blued", "Parkerized", "Stainless", "Nickel", "Case Hardened", "Cerakote", "Nitride", "Anodized", "In the White", "Other"] },
    { "key": "stock_grips", "label": "Stock / Grips", "type": "text", "section": "Specifications", "placeholder": "Walnut, synthetic, stag…" },
    { "key": "sights_optics", "label": "Sights / Optics", "type": "text", "section": "Specifications" },
    { "key": "modifications", "label": "Modifications", "type": "textarea", "section": "Specifications" },
    { "key": "condition", "label": "Condition (NRA)", "type": "select", "section": "Condition & Grading", "showInTable": true, "options": ["New In Box", "New", "Perfect", "Excellent", "Very Good", "Good", "Fair", "Poor"] },
    { "key": "bore_condition", "label": "Bore Condition", "type": "text", "section": "Condition & Grading", "placeholder": "Bright, sharp rifling…" },
    { "key": "matching_numbers", "label": "Matching Numbers", "type": "checkbox", "section": "Condition & Grading" },
    { "key": "included_extras", "label": "Included Extras", "type": "multiselect", "section": "Condition & Grading", "options": ["Original Box", "Manual", "Test Target", "Extra Magazines", "Sling", "Tools", "Factory Letter"] },
    { "key": "cr_eligible", "label": "C&R Eligible", "type": "checkbox", "section": "Condition & Grading", "help": "Curio & Relic: generally 50+ years old" },
    { "key": "nfa_item", "label": "NFA Item", "type": "checkbox", "section": "NFA / Compliance" },
    { "key": "nfa_type", "label": "NFA Type", "type": "select", "section": "NFA / Compliance", "options": ["Suppressor", "SBR", "SBS", "AOW", "Machine Gun", "Destructive Device"] },
    { "key": "form_type", "label": "Form Type", "type": "select", "section": "NFA / Compliance", "options": ["Form 1", "Form 3", "Form 4", "Form 5"] },
    { "key": "stamp_status", "label": "Tax Stamp Status", "type": "select", "section": "NFA / Compliance", "options": ["Not Started", "Submitted", "Pending", "Approved"] },
    { "key": "stamp_submitted", "label": "Stamp Submitted", "type": "date", "section": "NFA / Compliance" },
    { "key": "stamp_approved", "label": "Stamp Approved", "type": "date", "section": "NFA / Compliance" },
    { "key": "stamp_number", "label": "Stamp / Control Number", "type": "text", "section": "NFA / Compliance" },
    { "key": "owner_entity", "label": "Registered To", "type": "select", "section": "NFA / Compliance", "options": ["Individual", "Trust", "LLC"] },
    { "key": "trust_name", "label": "Trust / Entity Name", "type": "text", "section": "NFA / Compliance" },
    { "key": "storage_location", "label": "Storage Location", "type": "text", "section": "Storage", "placeholder": "Safe 1, shelf 2…" }
  ],
  "logTypes": [
    { "key": "range_session", "label": "Range Session", "icon": "target", "color": "#8a6d3b", "fields": [
      { "key": "rounds_fired", "label": "Rounds Fired", "type": "number", "unit": "rds" },
      { "key": "ammo_item_id", "label": "Ammunition Used", "type": "ammo_ref", "help": "Links to your ammo inventory and deducts the rounds automatically" },
      { "key": "distance", "label": "Distance", "type": "number", "unit": "yd" },
      { "key": "group_size", "label": "Best Group", "type": "number", "unit": "in" },
      { "key": "sight_adjustments", "label": "Sight Adjustments", "type": "text" },
      { "key": "malfunctions", "label": "Malfunctions", "type": "text", "placeholder": "None" },
      { "key": "location", "label": "Range / Location", "type": "text" }
    ] },
    { "key": "cleaning", "label": "Cleaning", "icon": "brush", "color": "#46647a", "fields": [
      { "key": "cleaning_type", "label": "Type", "type": "select", "options": ["Field Strip", "Detail Strip", "Bore Snake / Quick", "Lubrication Only"] },
      { "key": "products_used", "label": "Products Used", "type": "text" }
    ] },
    { "key": "modification", "label": "Modification", "icon": "wrench", "color": "#64748b", "fields": [
      { "key": "work_done", "label": "Work Done", "type": "text" },
      { "key": "gunsmith", "label": "Gunsmith / Shop", "type": "text" },
      { "key": "cost", "label": "Cost", "type": "currency" }
    ] },
    { "key": "appraisal", "label": "Appraisal", "icon": "badge", "color": "#b5952f", "fields": [
      { "key": "appraised_value", "label": "Appraised Value", "type": "currency" },
      { "key": "appraiser", "label": "Appraiser", "type": "text" }
    ] },
    { "key": "note", "label": "Note", "icon": "note", "color": "#6b7280", "fields": [] }
  ]
}
