    { "key": "grade", "label": "Grade", "type": "select", "section": "Grading", "showInTable": true, "options": ["PO-1", "FR-2", "AG-3", "G-4", "G-6", "VG-8", "VG-10", "F-12", "F-15", "VF-20", "VF-25", "VF-30", "VF-35", "XF-40", "XF-45", "AU-50", "AU-53", "AU-55", "AU-58", "MS-60", "MS-61", "MS-62", "MS-63", "MS-64", "MS-65", "MS-66", "MS-67", "MS-68", "MS-69", "MS-70", "PR-63", "PR-64", "PR-65", "PR-66", "PR-67", "PR-68", "PR-69", "PR-70"] },
    { "key": "certified", "label": "Certified / Slabbed", "type": "checkbox", "section": "Grading" },
    { "key": "cert_service", "label": "Grading Service", "type": "select", "section": "Grading", "options": ["PCGS", "NGC", "ANACS", "ICG", "CACG", "Other"] },
    { "key": "cert_number", "label": "Cert Number", "type": "text", "section": "Grading", "help": "Verifiable at pcgs.com/cert or ngccoin.com/certlookup" },
    { "key": "cac_sticker", "label": "CAC Sticker", "type": "checkbox", "section": "Grading" },
    { "key": "designation", "label": "Designation", "type": "text", "section": "Grading", "placeholder": "FB, FS, FH, FBL, CAM, DCAM, RD, RB, BN…" },
    { "key": "problems", "label": "Problems / Details Grade", "type": "text", "section": "Grading", "placeholder": "Cleaned, scratched, environmental damage…" },
    { "key": "holder_type", "label": "Holder", "type": "select", "section": "Storage", "options": ["Raw", "Slab", "2x2 Flip", "Air-Tite Capsule", "Album", "Tube", "Envelope"] },
    { "key": "storage_location", "label": "Storage Location", "type": "text", "section": "Storage" }
  ],
  "logTypes": [
