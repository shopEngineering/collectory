      { "key": "tier", "label": "Tier", "type": "text", "placeholder": "Economy, Regular, Express…" },
      { "key": "cost", "label": "Cost", "type": "currency" },
      { "key": "result_grade", "label": "Result Grade", "type": "text" },
      { "key": "cert_number", "label": "Cert Number", "type": "text" }
    ] },
    { "key": "storage_change", "label": "Storage Change", "icon": "archive", "color": "#64748b", "fields": [
      { "key": "new_location", "label": "New Location", "type": "text" }
    ] },
    { "key": "note", "label": "Note", "icon": "note", "color": "#6b7280", "fields": [] }
  ]
