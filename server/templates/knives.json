    { "key": "lock_type", "label": "Lock", "type": "select", "section": "Handle & Lock", "options": ["Liner Lock", "Frame Lock", "Back Lock", "Slip Joint", "Crossbar / AXIS", "Compression", "Button Lock", "Friction", "Collar / Ring", "Fixed — N/A"] },
    { "key": "deployment", "label": "Deployment", "type": "select", "section": "Handle & Lock", "options": ["Nail Nick", "Thumb Stud", "Thumb Hole", "Flipper", "Assisted", "Automatic", "Two-Hand"] },
    { "key": "pocket_clip", "label": "Pocket Clip", "type": "checkbox", "section": "Handle & Lock" },
    { "key": "condition", "label": "Condition", "type": "select", "section": "Condition", "showInTable": true, "options": ["Mint", "Near Mint", "Excellent", "Very Good", "Good", "Fair", "Poor"] },
    { "key": "blade_play", "label": "Blade Play", "type": "select", "section": "Condition", "options": ["None", "Slight", "Moderate"] },
